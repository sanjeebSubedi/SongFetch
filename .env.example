# Ollama settings.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_TEMPERATURE=0

# iTunes metadata settings.
ITUNES_BASE_URL=https://itunes.apple.com/search
ITUNES_COUNTRY=US

# LRCLIB settings.
LRCLIB_USER_AGENT=audio-agent/0.1.0

# Spotify scraper settings.
SPOTIFY_BROWSER_TYPE=selenium
SPOTIFY_BROWSER_NAME=chrome
SPOTIFY_HEADLESS=true
SPOTIFY_USE_WEBDRIVER_MANAGER=true

# Optional timing overrides for slower machines or flaky network/browser sessions.
SPOTIFY_TIMEOUT_SECONDS=10
SPOTIFY_SCROLL_PAUSE_SECONDS=1.2
SPOTIFY_MAX_IDLE_SCROLLS=12

# yt-dlp settings for YouTube challenge-solving and browser auth.
YTDLP_COOKIES_BROWSER=firefox
YTDLP_COOKIES_PROFILE=
YTDLP_JS_RUNTIME=node
YTDLP_REMOTE_COMPONENTS=ejs:github
